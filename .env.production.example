# =============================================================================
# IOCM Production Environment Variables
# Viện Nghiên cứu Ứng dụng Công nghệ & Đổi mới sáng tạo
# =============================================================================
# Copy file này thành .env.production và điền giá trị thật
# KHÔNG commit file .env.production vào git
# =============================================================================

# -----------------------------------------------------------------------------
# Database — PostgreSQL
# Chuỗi kết nối PostgreSQL production
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://iocm:THAY_PASSWORD_MANH@postgres:5432/iocm?schema=public"
POSTGRES_USER="iocm"
POSTGRES_PASSWORD="THAY_PASSWORD_MANH"
POSTGRES_DB="iocm"

# -----------------------------------------------------------------------------
# NextAuth — Authentication
# NEXTAUTH_SECRET: tạo bằng `openssl rand -base64 32`
# NEXTAUTH_URL: domain thật của hệ thống (có https)
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET="THAY_BANG_CHUOI_NGAU_NHIEN_32_BYTE"
NEXTAUTH_URL="https://iocm.vien-nghien-cuu.vn"

# -----------------------------------------------------------------------------
# Redis — Sessions, Socket.io, Cache
# Dùng password mạnh cho Redis production
# -----------------------------------------------------------------------------
REDIS_URL="redis://:THAY_REDIS_PASSWORD@redis:6379"
REDIS_PASSWORD="THAY_REDIS_PASSWORD"

# -----------------------------------------------------------------------------
# File Storage — S3/MinIO
# Nếu dùng AWS S3: điền access key, secret, bucket, region
# Nếu dùng MinIO self-hosted: điền endpoint MinIO
# -----------------------------------------------------------------------------
STORAGE_PROVIDER="s3"
S3_ENDPOINT="https://s3.vien-nghien-cuu.vn"
S3_ACCESS_KEY="THAY_S3_ACCESS_KEY"
S3_SECRET_KEY="THAY_S3_SECRET_KEY"
S3_BUCKET="iocm-files"
S3_REGION="ap-southeast-1"

# -----------------------------------------------------------------------------
# Email — SMTP (Gửi thông báo, invoice, nhắc nhở)
# Có thể dùng: Resend, SendGrid, Mailgun, hoặc SMTP server riêng
# -----------------------------------------------------------------------------
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@vien-nghien-cuu.vn"
SMTP_PASSWORD="THAY_SMTP_PASSWORD"
SMTP_FROM="IOCM <noreply@vien-nghien-cuu.vn>"
# Bật/tắt gửi email thật (false = chỉ log, không gửi)
SMTP_ENABLED="true"

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
NODE_ENV="production"
PORT="3000"

# Tên hiển thị của hệ thống
APP_NAME="IOCM - Viện Nghiên cứu Ứng dụng Công nghệ"
APP_URL="https://iocm.vien-nghien-cuu.vn"

# Giới hạn upload file (MB)
MAX_FILE_SIZE_MB="50"

# -----------------------------------------------------------------------------
# Backup — Cấu hình backup database
# Thư mục lưu backup trên host
# -----------------------------------------------------------------------------
BACKUP_DIR="/backups"
BACKUP_RETENTION_DAYS="7"
BACKUP_RETENTION_WEEKS="4"

# -----------------------------------------------------------------------------
# Logging
# Mức log: debug, info, warn, error
# -----------------------------------------------------------------------------
LOG_LEVEL="info"

# -----------------------------------------------------------------------------
# Security
# Số lần đăng nhập sai trước khi khóa tài khoản
# Thời gian khóa (phút)
# -----------------------------------------------------------------------------
MAX_LOGIN_ATTEMPTS="5"
LOCKOUT_DURATION_MINUTES="30"

# -----------------------------------------------------------------------------
# Notifications — Cấu hình cảnh báo
# Số ngày trước khi hợp đồng hết hạn để gửi cảnh báo
# -----------------------------------------------------------------------------
CONTRACT_EXPIRY_ALERT_DAYS="60,30,7"
FEE_OVERDUE_ALERT_DAYS="7,14,30"
LEGAL_BASIS_VERIFY_DAYS="180"
